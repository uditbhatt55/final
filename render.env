# Render environment variables template
# Copy these key=value lines into Render service Environment (mark secrets where appropriate)

# Required
GROQ_API_KEY=
FLASK_SECRET_KEY=
PORT=5000

# Platform / runtime
PYTHON_VERSION=3.12.3
GROQ_MODEL=llama-3.1-8b-instant

# TensorFlow / performance tuning (optional)
TF_CPP_MIN_LOG_LEVEL=2
TF_ENABLE_ONEDNN_OPTS=1
OMP_NUM_THREADS=4
MKL_NUM_THREADS=4
TF_NUM_INTRAOP_THREADS=2
TF_NUM_INTEROP_THREADS=2

# Optional
LOG_LEVEL=info
TZ=UTC

# Optional S3 (if you persist artifacts externally)
S3_BUCKET=
S3_REGION=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=